<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="750" prefWidth="1000" styleClass="app-root" stylesheets="@app.css"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.m11techlogapp.controller.UpdateRecordsController">

   <children>
      <VBox styleClass="app-shell" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
         <HBox alignment="CENTER_LEFT" styleClass="top-bar">
            <Region HBox.hgrow="ALWAYS"/>
            <Label styleClass="app-title" text="M11 TECH LOG"/>
            <Region HBox.hgrow="ALWAYS"/>
         </HBox>

         <HBox alignment="CENTER" styleClass="page-ribbon">
            <Label styleClass="page-heading" text="Update Records"/>
         </HBox>

         <VBox alignment="TOP_CENTER" spacing="28" styleClass="content" VBox.vgrow="ALWAYS">
            <HBox alignment="TOP_CENTER" maxWidth="900" spacing="70" VBox.vgrow="ALWAYS">
               <VBox alignment="TOP_CENTER" prefWidth="300" spacing="16" styleClass="panel">
                  <Label styleClass="section-title" text="Update Database"/>
                  <Button onAction="#uploadFile" prefWidth="190" styleClass="secondary-button" text="Update With Excel File"/>
                  <Button onAction="#clearDB" prefWidth="190" styleClass="danger-button" text="Clear All Records"/>
               </VBox>

               <VBox alignment="TOP_CENTER" prefWidth="460" spacing="16" styleClass="panel">
                  <Label styleClass="section-title" text="Insert Individual Record"/>

                  <GridPane alignment="CENTER" hgap="15" vgap="13">
                     <columnConstraints>
                        <ColumnConstraints halignment="RIGHT" minWidth="150"/>
                        <ColumnConstraints halignment="LEFT" minWidth="250"/>
                     </columnConstraints>

                     <Label styleClass="field-label" text="Date/Time:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                     <DatePicker fx:id="dttmField" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                     <Label styleClass="field-label" text="Name:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                     <TextField fx:id="nameField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                     <Label styleClass="field-label" text="Nomenclature:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                     <TextField fx:id="nomenField" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                     <Label styleClass="field-label" text="Malfunction Code:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                     <ComboBox fx:id="malCdField" onMouseClicked="#initializeMalCd" promptText="Select..." GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                     <Label styleClass="field-label" text="Hours:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                     <Spinner fx:id="hoursField" GridPane.columnIndex="1" GridPane.rowIndex="4">
                        <valueFactory>
                           <SpinnerValueFactory.DoubleSpinnerValueFactory amountToStepBy="0.1" initialValue="1" max="24" min=".2"/>
                        </valueFactory>
                     </Spinner>

                     <Label styleClass="field-label" text="Corrective Action:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                     <TextField fx:id="corrActField" GridPane.columnIndex="1" GridPane.rowIndex="5"/>

                     <Button alignment="CENTER" onAction="#addIndividualRecord" prefHeight="28" styleClass="primary-button" text="Add Individual Record" GridPane.columnIndex="1" GridPane.rowIndex="6"/>
                     <rowConstraints>
                        <RowConstraints/>
                        <RowConstraints/>
                        <RowConstraints/>
                        <RowConstraints/>
                        <RowConstraints/>
                        <RowConstraints/>
                        <RowConstraints/>
                     </rowConstraints>
                  </GridPane>
               </VBox>
            </HBox>

            <Button onAction="#switchToMainPage" prefHeight="28" prefWidth="170" styleClass="return-button" text="Return to Main Page"/>
         </VBox>
      </VBox>
   </children>
</AnchorPane>
