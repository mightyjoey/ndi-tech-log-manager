<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="750" prefWidth="1000" styleClass="app-root" stylesheets="@app.css"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.m11techlogapp.controller.MainPageController">

   <children>
      <VBox styleClass="app-shell" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
         <HBox alignment="CENTER_LEFT" styleClass="top-bar">
            <Region HBox.hgrow="ALWAYS"/>
            <Label styleClass="app-title" text="M11 TECH LOG"/>
            <Region HBox.hgrow="ALWAYS"/>
         </HBox>

         <HBox alignment="CENTER" styleClass="page-ribbon">
            <Label styleClass="page-heading" text="Main Dashboard"/>
         </HBox>

         <VBox alignment="TOP_CENTER" spacing="18" styleClass="content" VBox.vgrow="ALWAYS">
            <VBox maxWidth="760" spacing="18">
               <VBox spacing="8" styleClass="dashboard-panel">
                  <HBox alignment="CENTER_LEFT" spacing="18">
                     <Label styleClass="section-title" text="+"/>
                     <Button mnemonicParsing="false" onAction="#switchToGenerateLogs" styleClass="secondary-button" text="Generate Logs"/>
                  </HBox>
                  <Label styleClass="helper-text" text="Create inspection history and export work logs."/>
               </VBox>

               <VBox spacing="8" styleClass="dashboard-panel">
                  <HBox alignment="CENTER_LEFT" spacing="18">
                     <Label styleClass="section-title" text="?"/>
                     <Button mnemonicParsing="false" onAction="#switchToSearch" styleClass="secondary-button" text="Search by Key Word"/>
                  </HBox>
                  <Label styleClass="helper-text" text="Find existing records by keyword."/>
               </VBox>

               <VBox spacing="8" styleClass="dashboard-panel">
                  <HBox alignment="CENTER_LEFT" spacing="18">
                     <Label styleClass="section-title" text="..."/>
                     <Button mnemonicParsing="false" onAction="#switchToUpdateRecords" styleClass="secondary-button" text="Update Records"/>
                  </HBox>
                  <Label styleClass="helper-text" text="Upload records or add an individual entry."/>
               </VBox>
            </VBox>
         </VBox>
      </VBox>
   </children>
</AnchorPane>
