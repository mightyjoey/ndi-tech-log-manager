<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="750" prefWidth="1000" styleClass="app-root" stylesheets="@app.css"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.m11techlogapp.controller.OutputLogController">

    <children>
        <VBox styleClass="app-shell" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
            <HBox alignment="CENTER_LEFT" styleClass="top-bar">
                <Region HBox.hgrow="ALWAYS"/>
                <Label styleClass="app-title" text="M11 TECH LOG"/>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>

            <HBox alignment="CENTER" styleClass="page-ribbon">
                <Label styleClass="page-heading" text="Inspection History"/>
            </HBox>

            <VBox spacing="14" styleClass="content" VBox.vgrow="ALWAYS">
                <TableView fx:id="tableView" prefHeight="360" VBox.vgrow="ALWAYS"/>

                <Label fx:id="totalHoursLabel" alignment="CENTER" maxWidth="Infinity" styleClass="summary-label" text="Total Inspections Performed:          Total Hours:      " textAlignment="CENTER"/>

                <HBox alignment="CENTER" spacing="14" styleClass="panel">
                    <VBox alignment="CENTER_LEFT" spacing="4">
                        <Label styleClass="field-label" text="Date/Time:"/>
                        <DatePicker fx:id="dttmField" prefHeight="26.0" prefWidth="110.0"/>
                    </VBox>

                    <VBox alignment="CENTER_LEFT" spacing="4">
                        <Label styleClass="field-label" text="Name:"/>
                        <TextField fx:id="newNameField" prefHeight="26.0" prefWidth="110.0"/>
                    </VBox>
                    <VBox alignment="CENTER_LEFT" spacing="4">
                        <Label styleClass="field-label" text="Nomenclature:"/>
                        <TextField fx:id="nomenField" prefHeight="26.0" prefWidth="120.0"/>
                    </VBox>
                    <VBox alignment="CENTER_LEFT" spacing="4">
                        <Label styleClass="field-label" text="Malfunction Code:"/>
                        <ComboBox fx:id="malCdField" onMouseClicked="#initializeMalCd" prefHeight="26.0" prefWidth="130.0" promptText="Select..."/>
                    </VBox>
                    <VBox alignment="CENTER_LEFT" spacing="4">
                        <Label styleClass="field-label" text="Hours:"/>
                        <Spinner fx:id="hoursField" prefHeight="26.0" prefWidth="78.0">
                            <valueFactory>
                                <SpinnerValueFactory.DoubleSpinnerValueFactory amountToStepBy="0.1" initialValue="1" max="24" min=".2"/>
                            </valueFactory>
                        </Spinner>
                    </VBox>
                    <VBox alignment="CENTER_LEFT" spacing="4">
                        <Label styleClass="field-label" text="Corrective Action:"/>
                        <TextField fx:id="corrActField" prefHeight="26.0" prefWidth="150.0"/>
                    </VBox>
                    <VBox alignment="BOTTOM_CENTER" spacing="4">
                        <Button alignment="CENTER" onAction="#addIndividualRecord" prefHeight="28" styleClass="secondary-button" text="Add Individual Record"/>
                    </VBox>
                </HBox>

                <HBox alignment="CENTER" maxWidth="Infinity" spacing="26">
                    <VBox alignment="CENTER_LEFT" spacing="8">
                        <TextField fx:id="nameField" prefWidth="200" promptText="Enter name"/>
                        <TextField fx:id="rankField" prefWidth="200" promptText="Enter rank / rate"/>
                        <TextField fx:id="organizationField" prefWidth="200" promptText="Enter organization"/>
                    </VBox>

                    <VBox alignment="CENTER" spacing="12">
                        <Button onAction="#exportPDF" prefWidth="170" styleClass="primary-button" text="Export as PDF"/>
                        <Button onAction="#switchToGenerateLogs" prefWidth="170" styleClass="return-button" text="Return to Generate Log"/>
                    </VBox>
                </HBox>
            </VBox>
        </VBox>
    </children>
</AnchorPane>
